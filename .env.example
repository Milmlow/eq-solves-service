# Copy to .env.local and fill in the values for your own Supabase project.
# The .env file is git-ignored — never commit real keys.
#
# For production: the deployed app reads from /config.js instead of env vars.
# This .env is for local `npm run dev` only.

# Public — used by the front-end. Safe to expose (anon key is public by design).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — used by the optional seed scripts.
# Do NOT commit. Do NOT bundle into the front-end.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
