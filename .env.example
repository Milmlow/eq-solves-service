# EQ Solves — environment variables
# Copy this file to .env.local and fill in the values.

# Public (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Platform-admin secret for the out-of-band tenant-provisioning endpoints
# (/api/tenants). Cross-tenant provisioning is NOT a tenant role (migration
# 0114) — EQ-internal tooling presents this in the `x-eq-platform-key` header
# and the endpoint runs with the service role. 32-byte hex via
# `openssl rand -hex 32`. Set in Netlify env only; never commit the real value.
# Endpoints return 503 when unset.
EQ_PLATFORM_ADMIN_KEY=

# Required: shared HMAC key — must match eq-shell, eq-solves-field, eq-cards.
# Set in Netlify → Site Settings → Environment Variables → Builds scope.
# Never put the real value here.
EQ_SECRET_SALT=

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_your-api-key

# Analytics (all optional — if unset, PostHog + Clarity silently no-op)
# PostHog project key for browser-side capture. EU region key recommended.
NEXT_PUBLIC_POSTHOG_KEY=
# e.g. https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=
# Microsoft Clarity project ID (session replay + heatmaps)
NEXT_PUBLIC_CLARITY_ID=
# One of: beta | production | demo | development — stamped on every event
NEXT_PUBLIC_APP_ENV=beta

# Server-side PostHog (for Server Action events that must not be dropped)
POSTHOG_KEY=
POSTHOG_HOST=

# Reports — Gotenberg HTML→PDF service (deployed via infra/gotenberg/fly.toml)
GOTENBERG_URL=https://eq-solves-gotenberg.fly.dev

# Cron / dispatcher (32-byte hex via `openssl rand -hex 32`)
# Must match the value in Supabase Vault (vault.create_secret(<hex>, 'cron_secret'))
CRON_SECRET=

# Customer email unsubscribe token signing (32-byte hex via `openssl rand -hex 32`)
# Used to sign /portal/unsubscribe?token=... links. AU Spam Act 2003 s18.
UNSUBSCRIBE_SECRET=

# Overnight battle-test credentials (provisioned via `npx tsx scripts/bootstrap-battle-test-users.ts`)
# Service-role mint flow: agent uses Supabase admin.generateLink() per run.
BATTLE_TEST_ADMIN_EMAIL=battle-test-admin@eq.solutions
BATTLE_TEST_ADMIN_UUID=
BATTLE_TEST_PORTAL_EMAIL=battle-test-portal@eq.solutions
BATTLE_TEST_PORTAL_UUID=
BATTLE_TEST_PORTAL_CUSTOMER_ID=
BATTLE_TEST_PORTAL_CONTACT_ID=


# Canonical write-through sync (EQ Intake / canonical Supabase)
# These are required for PPM data (assets, test results, defects) to sync
# to the canonical layer. Safe to leave blank in dev — syncs are skipped
# silently when CANONICAL_API_KEY_SERVICE is unset.
CANONICAL_API_URL=https://core.eq.solutions
CANONICAL_API_KEY_SERVICE=
CANONICAL_TENANT_SLUG=sks

# Site credentials column-level encryption (S3-6)
# Symmetric key for pgp_sym_encrypt/decrypt on site_credentials.password_enc
# and site_credentials.username_enc. NOT stored in Postgres — injected at
# query time by the API route. Min 32 chars; generate with:
#   openssl rand -base64 32
# Set in Netlify env only (never commit the real value).
# After setting, run: npx tsx scripts/rekey-site-credentials.ts
# Endpoints return 503 when unset.
SITE_CREDENTIALS_KEY=
