# EQ Solves — environment variables
# Copy this file to .env.local and fill in the values.

# Public (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_your-api-key

# Analytics (all optional — if unset, PostHog + Clarity silently no-op)
# PostHog project key for browser-side capture. EU region key recommended.
NEXT_PUBLIC_POSTHOG_KEY=
# e.g. https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=
# Microsoft Clarity project ID (session replay + heatmaps)
NEXT_PUBLIC_CLARITY_ID=
# One of: beta | production | demo | development — stamped on every event
NEXT_PUBLIC_APP_ENV=beta

# Server-side PostHog (for Server Action events that must not be dropped)
POSTHOG_KEY=
POSTHOG_HOST=
